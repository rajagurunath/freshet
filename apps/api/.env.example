# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings: local | hash
# "local" uses sentence-transformers all-MiniLM-L6-v2 (384-dim, no API key needed)
# "hash"  uses deterministic hashing (fully offline, useful for CI)
EMBEDDING_PROVIDER=local

# S3 raw-blob storage (leave blank to use local filesystem under BLOB_DIR)
S3_BUCKET=
AWS_REGION=us-east-1

# LanceDB vector store (local path or s3://bucket/prefix)
LANCEDB_URI=./data/lancedb

# Local blob store fallback (used when S3_BUCKET is not set)
BLOB_DIR=./data/blobs

# Comma-separated list of allowed bearer tokens
API_KEYS=dev-key

# Deployment environment. Anything other than development/dev/local/test makes
# the app refuse to start (or mint/verify tokens) while the signing secrets
# below are left at their insecure defaults.
ENVIRONMENT=development

# HMAC signing secrets for download/share tokens. MUST be set to random values
# in production (e.g. `openssl rand -hex 32`); the defaults below are public and
# forgeable.
ASSET_TOKEN_SECRET=changeme-asset-token-secret
SHARE_TOKEN_SECRET=changeme-share-token-secret

# Comma-separated allowed CORS origins (leave blank for no CORS restriction in dev)
CORS_ORIGINS=http://localhost:1420,http://localhost:5173

# Compress transcripts with headroom-ai before LLM summarize/graph-extract jobs.
# Requires the optional extra: pip install 'contexthub[compress]'.
# Off by default; falls back to passthrough on any error, never fails a job.
COMPRESS_BEFORE_LLM=false

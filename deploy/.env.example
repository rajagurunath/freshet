# Freshet hub — production config. Copy to `.env` and fill in.
#   cp .env.example .env

# The image to run (built + pushed by .github/workflows/docker.yml).
API_IMAGE=ghcr.io/rajagurunath/freshet-api:latest

# --- TLS / domain (Caddy gets a Let's Encrypt cert for this) ---
FRESHET_DOMAIN=hub.example.com

# --- Auth (REQUIRED — never ship the dev-key in prod) ---
# Comma-separated. Each key may be "key" or "key:user_id:team".
API_KEYS=CHANGE_ME_long_random_key:alice:eng,CHANGE_ME_another:bob:eng
# Random secrets for signed asset/share tokens (the hub refuses to start in
# production if these are left at their insecure defaults).
ASSET_TOKEN_SECRET=CHANGE_ME_random_32_bytes
SHARE_TOKEN_SECRET=CHANGE_ME_random_32_bytes

# Desktop app origins allowed to call this hub.
CORS_ORIGINS=http://localhost:1420,tauri://localhost

# --- Storage: leave S3_BUCKET empty to store raw session blobs on the disk
#     volume; set it to store them in S3 instead (LanceDB/graph still on disk). ---
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- LLM for summaries + RAG answers (optional).
#     With none set, embeddings fall back to local/hash and RAG returns raw excerpts. ---
EMBEDDING_PROVIDER=local
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
